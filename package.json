{
    "name": "mvt-games",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "imports": {
        "#common": "./src/common/index.ts",
        "#pixi-jsx": "./src/pixi-jsx/index.ts",
        "#pixi-jsx/jsx-runtime": "./src/pixi-jsx/jsx-runtime.ts",
        "#pixi-jsx/jsx-dev-runtime": "./src/pixi-jsx/jsx-runtime.ts"
    },
    "scripts": {
        "dev": "vite --host",
        "build": "tsc && vite build && vitepress build docs",
        "build:site": "tsc && vite build",
        "build:docs": "vitepress build docs",
        "docs:dev": "vitepress dev docs --port 5200",
        "preview": "vite preview",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "bench": "vitest bench --run",
        "test": "vitest run",
        "test:watch": "vitest",
        "generate-textures": "tsx scripts/generate-textures.ts"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@stylistic/eslint-plugin": "^5.5.0",
        "@types/glob": "^8.1.0",
        "@types/lz-string": "^1.3.34",
        "@types/pngjs": "^6.0.5",
        "eslint": "^9.39.4",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "glob": "^13.0.6",
        "mermaid": "^11.13.0",
        "pngjs": "^7.0.0",
        "solid-js": "^1.9.11",
        "tsx": "^4.21.0",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.56.1",
        "vite": "^7.3.1",
        "vitepress": "^1.6.4",
        "vitepress-plugin-mermaid": "^2.0.17",
        "vitest": "^4.1.0"
    },
    "dependencies": {
        "@codemirror/lang-javascript": "^6.2.5",
        "@codemirror/theme-one-dark": "^6.1.3",
        "codemirror": "^6.0.2",
        "gsap": "^3.14.2",
        "lz-string": "^1.5.0",
        "pixi.js": "^8.16.0",
        "sucrase": "^3.35.1"
    },
    "optionalDependencies": {
        "@rollup/rollup-linux-x64-gnu": "4.59.0"
    }
}
